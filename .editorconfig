# ─────────────────────────────────────────────────────────────────────────────
# EditorConfig — Consistent formatting across all editors and IDEs
# https://editorconfig.org
# ─────────────────────────────────────────────────────────────────────────────

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.py]
indent_size = 4
max_line_length = 100

[*.{js,css,html}]
indent_size = 4

[*.{yml,yaml,json,toml}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false

[Dockerfile]
indent_size = 4
