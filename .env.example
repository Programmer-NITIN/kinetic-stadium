# ─────────────────────────────────────────────────────────────────────────────
# CrowdPulse AI — Environment Configuration
# Copy this file to .env and fill in your values.
# All Google services are OPTIONAL — the app runs fully on mocks when absent.
# ─────────────────────────────────────────────────────────────────────────────

# ── Core ──────────────────────────────────────────────────────────────────────
# Set to 'true' during local development only.
# In production this MUST be 'false'.
DEBUG=true

# Show /docs and /redoc interactive API docs. Set to 'false' in production.
DOCS_ENABLED=true

# ── Gemini AI (required for AI explanations and chatbot) ──────────────────────
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_TIMEOUT_SECONDS=8

# ── Google Cloud (leave empty to use in-memory mocks) ─────────────────────────
GCP_PROJECT_ID=
FIRESTORE_ENABLED=false
BIGQUERY_ENABLED=false
MAPS_ENABLED=false
MAPS_API_KEY=
CLOUD_LOGGING_ENABLED=false

# ── Firebase Authentication ───────────────────────────────────────────────────
# Path to Firebase service account JSON (for server-side token verification).
# Leave empty to run in mock-auth mode.
FIREBASE_CREDENTIALS_PATH=
FIREBASE_AUTH_ENABLED=false

# ── Security (production only) ────────────────────────────────────────────────
# Comma-separated list of allowed CORS origins.
# Example: ALLOWED_ORIGINS=https://crowdpulse.run.app,https://admin.crowdpulse.run.app
# Leave empty in debug mode — wildcard CORS is used automatically.
ALLOWED_ORIGINS=
